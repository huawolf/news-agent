# LLM API 配置
DEEPSEEK_API_KEY=sk-or-v1-...

# Feishu Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/...

# 可选：添加 token 的免费限额更高，不加也基本够用
# GITHUB_TOKEN=
# JINA_API_KEY=

# 可选：个人偏好提示词（会注入到 LLM 评分 prompt 中，例如：“偏好 LLM, Agent, Web 开发相关内容”）
# PERSONAL_PREFERENCES=

# 可选：自定义推送平台配置（如果启用 custom 推送）
# CUSTOM_PUSH_URL=https://your-custom-api.com/push
# CUSTOM_PUSH_TOKEN=your_custom_auth_token_here
